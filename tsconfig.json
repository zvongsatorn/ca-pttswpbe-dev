{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "fixdb.ts",
    "tmp_sp.ts",
    "test*.ts",
    "check*.ts",
    "chk.ts",
    "debug*.ts",
    "apply_sp_fix.ts",
    "get_*.ts"
  ]
}